{
  "annotations": { "list": [] },
  "description": "AI Engine Provider Health & Circuit Breaker Status",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "type": "stat",
      "title": "Healthy Providers",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "targets": [{
        "expr": "count(ai_engine_provider_success_total > 0)",
        "legendFormat": "healthy"
      }],
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }] } }
      }
    },
    {
      "type": "stat",
      "title": "Open Circuit Breakers",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "targets": [{
        "expr": "sum(ai_engine_circuit_breaker_state == 1)",
        "legendFormat": "open"
      }],
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } }
      }
    },
    {
      "type": "stat",
      "title": "Cache Hit Rate",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "targets": [{
        "expr": "sum(rate(ai_engine_cache_hits_total[5m])) / sum(rate(ai_engine_cache_requests_total[5m])) * 100",
        "legendFormat": "{{}}%"
      }],
      "fieldConfig": {
        "defaults": { "unit": "percent", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 50 }, { "color": "green", "value": 80 }] } }
      }
    },
    {
      "type": "stat",
      "title": "Avg Response Time",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "targets": [{
        "expr": "histogram_quantile(0.95, sum(rate(ai_engine_request_duration_seconds_bucket[5m])) by (le))",
        "legendFormat": "p95"
      }],
      "fieldConfig": {
        "defaults": { "unit": "s", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 5 }, { "color": "red", "value": 15 }] } }
      }
    },
    {
      "type": "timeseries",
      "title": "Requests per Second by Provider",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [{
        "expr": "sum(rate(ai_engine_request_duration_seconds_count[5m])) by (provider)",
        "legendFormat": "{{provider}}"
      }]
    },
    {
      "type": "timeseries",
      "title": "Request Success Rate by Provider",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [{
        "expr": "sum(rate(ai_engine_request_duration_seconds_count{status=\"success\"}[5m])) by (provider) / sum(rate(ai_engine_request_duration_seconds_count[5m])) by (provider) * 100",
        "legendFormat": "{{provider}}"
      }],
      "fieldConfig": {
        "defaults": { "unit": "percent", "min": 0, "max": 100 }
      }
    },
    {
      "type": "timeseries",
      "title": "Provider Latency (p50 / p95 / p99)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(ai_engine_request_duration_seconds_bucket[5m])) by (le, provider))", "legendFormat": "p50 {{provider}}" },
        { "expr": "histogram_quantile(0.95, sum(rate(ai_engine_request_duration_seconds_bucket[5m])) by (le, provider))", "legendFormat": "p95 {{provider}}" },
        { "expr": "histogram_quantile(0.99, sum(rate(ai_engine_request_duration_seconds_bucket[5m])) by (le, provider))", "legendFormat": "p99 {{provider}}" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "type": "timeseries",
      "title": "Circuit Breaker Failures",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [{
        "expr": "sum(rate(ai_engine_circuit_breaker_failures_total[5m])) by (breaker)",
        "legendFormat": "{{breaker}}"
      }]
    },
    {
      "type": "timeseries",
      "title": "Cache Size & Memory",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "targets": [
        { "expr": "ai_engine_cache_size", "legendFormat": "Entries" },
        { "expr": "ai_engine_cache_memory_bytes", "legendFormat": "Memory (bytes)" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Errors by Type",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "targets": [{
        "expr": "sum(rate(ai_engine_errors_total[5m])) by (error_type, provider)",
        "legendFormat": "{{provider}}: {{error_type}}"
      }]
    },
    {
      "type": "table",
      "title": "Active Alerts",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 28 },
      "targets": [{
        "expr": "ALERTS{alertstate=\"firing\", job=\"ai_engine\"}",
        "format": "table",
        "instant": true
      }],
      "transformations": [{
        "id": "organize",
        "options": {
          "excludeByName": { "Time": false },
          "renameByName": { "alertname": "Alert", "alertstate": "State", "severity": "Severity" }
        }
      }]
    }
  ],
  "schemaVersion": 39,
  "tags": ["ai-engine", "providers"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "AI Engine — Provider Health",
  "uid": "ai-engine-provider-health"
}
