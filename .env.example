# AI Engine Environment Variables
# Copy this file to .env and fill in your values

# ============================================================
# GPT4Free (RECOMMENDED - Truly Free)
# ============================================================
# Run g4f server: docker run -p 8080:8080 hlohaus789/g4f
# Or install: pip install g4f && python -m g4f
G4F_ENDPOINT=http://localhost:8080/v1/chat/completions
G4F_MODELS_ENDPOINT=http://localhost:8080/v1/models

# ============================================================
# Provider API Keys (Free Tiers)
# ============================================================

# Groq (Free: 30 RPM, 14,400 RPD)
# Sign up: https://console.groq.com
GROQ_API_KEY=

# SambaNova (Free: generous daily limits)
# Sign up: https://cloud.sambanova.ai
SAMBANOVA_API_KEY=

# Together AI (Free: $1 credit on signup)
# Sign up: https://api.together.xyz
TOGETHER_API_KEY=

# DeepInfra (Free: $1 credit on signup)
# Sign up: https://deepinfra.com
DEEPINFRA_API_KEY=

# OpenRouter (Free: 200 credits + free models)
# Sign up: https://openrouter.ai
OPENROUTER_API_KEY=

# NVIDIA NIM (Free: 1000 credits/month)
# Sign up: https://build.nvidia.com
NVIDIA_API_KEY=

# Cerebras (Free: 30 RPM)
# Sign up: https://cloud.cerebras.ai
CEREBRAS_API_KEY=

# Cloudflare Workers AI (Free: 10K neurons/day)
# Sign up: https://dash.cloudflare.com
CLOUDFLARE_API_KEY=
CLOUDFLARE_ACCOUNT_ID=

# Google Gemini (Free: 15 RPM, 1M tokens/day)
# Sign up: https://aistudio.google.com
GEMINI_API_KEY=

# GitHub Models (Free: 15 RPM)
# Sign up: https://github.com/marketplace/models
GITHUB_API_KEY=

# Vercel AI Gateway (Free tier available)
VERCEL_API_KEY=

# ============================================================
# Discord-Based Free APIs (from zukixa/cool-ai-stuff)
# Join Discord → Get free API key → Use free models
# ============================================================

# NagaAI - Free tier (Join Discord: https://discord.gg/8ywEPhnJy4)
NAGAAI_API_KEY=

# NavyAPI - Free tier (Join Discord: https://discord.gg/ezXZ8wpprc)
NAVY_API_KEY=

# ElectronHub - Free tier (Join Discord: https://discord.gg/4xg2TM3mNP)
ELECTRONHUB_API_KEY=

# MNN AI - Free tier (Join Discord: https://discord.gg/xKmsCCzUFW)
MNN_API_KEY=

# ============================================================
# Server Configuration
# ============================================================

# Admin API key for management endpoints
ADMIN_API_KEY=

# CORS origins (comma-separated for multiple)
CORS_ORIGINS=*
