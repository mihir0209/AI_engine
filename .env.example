# AI Engine Environment Variables
# Copy this file to .env and fill in your values

# ============================================================
# Provider API Keys
# ============================================================

# OpenAI
OPENAI_API_KEY=
OPENAI_API_KEY_2=
OPENAI_API_KEY_3=

# Anthropic (Claude)
ANTHROPIC_API_KEY=

# Google Gemini
GEMINI_API_KEY=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=

# Groq
GROQ_API_KEY=
GROQ_API_KEY_2=
GROQ_API_KEY_3=

# A4F
A4F_API_KEY=
A4F_API_KEY_2=
A4F_API_KEY_3=

# ChatAnywhere (Chi)
CHI_API_KEY=
CHI_API_KEY_2=
CHI_API_KEY_3=

# Paxsenix
PAXSENIX_API_KEY=
PAXSENIX_API_KEY_2=
PAXSENIX_API_KEY_3=

# Mango
MANGO_API_KEY=
MANGO_API_KEY_2=
MANGO_API_KEY_3=

# Samurai
SAMURAI_API_KEY=
SAMURAI_API_KEY_2=
SAMURAI_API_KEY_3=

# TypeGPT
WOW_TYPEGPT_API_KEY=
WOW_TYPEGPT_API_KEY_2=
WOW_TYPEGPT_API_KEY_3=

# Cerebras
CEREBRAS_API_KEY=
CEREBRAS_API_KEY_2=
CEREBRAS_API_KEY_3=

# CloseRouter (CR)
CR_API_KEY=
CR_API_KEY_2=
CR_API_KEY_3=

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_API_KEY_2=
OPENROUTER_API_KEY_3=

# NVIDIA
NVIDIA_API_KEY=
NVIDIA_API_KEY_2=
NVIDIA_API_KEY_3=

# Vercel AI Gateway
VERCEL_API_KEY=
VERCEL_API_KEY_2=
VERCEL_API_KEY_3=

# GitHub Models
GITHUB_API_KEY=
GITHUB_API_KEY_2=
GITHUB_API_KEY_3=

# Flowith
FLOWITH_API_KEY=
FLOWITH_API_KEY_2=
FLOWITH_API_KEY_3=

# Minimax
MINIMAX_API_KEY=
MINIMAX_API_KEY_2=
MINIMAX_API_KEY_3=

# Pawan
PAWAN_API_KEY=
PAWAN_API_KEY_2=
PAWAN_API_KEY_3=

# Cohere
COHERE_API_KEY=
COHERE_API_KEY_2=
COHERE_API_KEY_3=

# Cloudflare Workers AI
CLOUDFLARE_API_KEY=
CLOUDFLARE_API_KEY_2=
CLOUDFLARE_API_KEY_3=
CLOUDFLARE_ACCOUNT_ID=

# Azure OpenAI
AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=https://YOUR_RESOURCE.openai.azure.com/openai/deployments/YOUR_DEPLOYMENT/chat/completions?api-version=2024-02-01

# AWS Bedrock
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ============================================================
# Server Configuration
# ============================================================

# Admin API key for management endpoints (toggle providers, etc.)
# Leave empty to allow all access (development mode)
ADMIN_API_KEY=

# CORS origins (comma-separated for multiple)
# Use * for development, specify domains for production
CORS_ORIGINS=*

# ============================================================
# Feature Flags
# ============================================================

# Enable verbose logging (true/false)
VERBOSE_MODE=false

# Enable auto-rotation of API keys
KEY_ROTATION_ENABLED=true

# Enable provider rotation on failure
PROVIDER_ROTATION_ENABLED=true
